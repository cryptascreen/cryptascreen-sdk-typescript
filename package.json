{
  "name": "@cryptascreen/sdk",
  "version": "0.1.0",
  "description": "Type-safe TypeScript client for the CryptaScreen REST API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "axios-mock-adapter": "^2.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "cryptascreen",
    "compliance",
    "screening",
    "sanctions",
    "crypto",
    "aml",
    "kyc"
  ],
  "license": "MIT"
}
